{
  "name": "tracked-instance",
  "version": "2.0.7",
  "description": "Build large forms and track all changes",
  "type": "module",
  "scripts": {
    "build": "tsc && esbuild ./src/index.ts --bundle --external:vue --outfile=./dist/index.mjs --format=esm --minify",
    "test-ui": "vitest --ui",
    "test": "vitest run"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rudnik275/tracked-instance.git"
  },
  "author": "Dmytro Rudnyk",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue 3",
    "vue3",
    "vue next",
    "tracked form",
    "track",
    "collection",
    "useTrackedInstance",
    "useCollection"
  ]
}
